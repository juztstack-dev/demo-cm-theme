<!DOCTYPE html>
<html lang="en">
<head>
{% block html_head_container %}
	
    {% include 'layouts/head.twig' %}
    
    <!-- Script from general settings -->
    {% if settings.code_js %}
    <script type="text/javascript">
        {{ settings.code_js|base64_decode|raw }}
    </script>
    {% endif %}
    {% set term = fn('get_queried_object') %}
    {{ snippet('seo', { post: post, term: term }) }}
    {% block head %}{% endblock %}

{% endblock %}
</head>
    <body class="{{body_class}}">
        <div data-preview-layout="header">
            <div data-preview-layout-inner="1">
                {% include "layouts/header.twig" %}
            </div>
        </div>
        <main class="">
            {% block content %}{% endblock %}
        </main>
        <div data-preview-layout="footer">
            <div data-preview-layout-inner="1">
                {% include "layouts/footer.twig" %}
            </div>
        </div>
        {% block footer %}{% endblock %}
        </footer>
        {{function('wp_footer')}}
    </body>
</html>
